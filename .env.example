# Provider API keys (required for actual API calls)
LLM_SOLAR_API_KEY=
LLM_CLAUDE_SONNET_API_KEY=
LLM_GPT_API_KEY=
LLM_GROK_API_KEY=

# Optional observability key (leave empty if unused)
LANGSMITH=

# --- Pinecone (벡터 DB, NLU RAG용 — 코드 연동 시 사용) ---
# 콘솔: 왼쪽 사이드바 → API Keys 에서 생성·복사
PINECONE_API_KEY=
# 콘솔: Database → Indexes → 인덱스 이름 (예: aicc-doum-index)
PINECONE_INDEX_NAME=aicc-doum-index
# 인덱스 생성 시 Dimension은 임베딩 차원과 일치해야 함 (예: solar-embedding-1-large → 4096)
# Host URL이 필요한 SDK/버전이면 Indexes 목록에서 해당 인덱스의 Host 복사
# PINECONE_HOST=https://aicc-doum-index-xxxxx.svc.aped-4627-b74a.pinecone.io

# Provider model names
LLM_SOLAR_MODEL=solar-pro3
LLM_CLAUDE_SONNET_MODEL=claude-sonnet-4-6
LLM_GPT_MODEL=gpt-4o
LLM_GROK_MODEL=grok-3

# Provider base URLs
LLM_SOLAR_BASE_URL=https://api.upstage.ai/v1
LLM_CLAUDE_SONNET_BASE_URL=https://api.anthropic.com/v1
LLM_GPT_BASE_URL=https://api.openai.com/v1
LLM_GROK_BASE_URL=https://api.x.ai/v1

# Google Vertex AI Gemini (uses GCP billing/credits)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
LLM_GOOGLE_VERTEX_MODEL=gemini-2.5-pro
JUDGE_GOOGLE_VERTEX_MODEL=gemini-3.1-pro-preview

# Evaluation judge model aliases
# EVALUATION_PROVIDER_GPT_MODEL is used as a fallback when JUDGE_OPENAI_MODEL is not set.
# EVALUATION_PROVIDER_CLAUDE_MODEL is used as a fallback when JUDGE_ANTHROPIC_MODEL is not set.
EVALUATION_PROVIDER_GPT_MODEL=gpt-5.5
EVALUATION_PROVIDER_CLAUDE_MODEL=claude-opus-4-7

# Runtime provider selection
STT_PROVIDER=openai
TTS_PROVIDER=openai
TTS_FALLBACK_PROVIDERS=google,azure
OPENAI_TTS_VOICE=shimmer

# Google Cloud (required when STT_PROVIDER=google or Google TTS fallback is used)
GOOGLE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# Azure TTS (required when azure TTS is used)
AZURE_SPEECH_KEY=
AZURE_SERVICE_REGION=
# 저장소 루트에 복사: cp .env.example .env 후 값 입력
# .env 는 Git에 커밋하지 마세요 (.gitignore 처리됨)
# Upstage 임베딩과 Solar LLM 모두 LLM_SOLAR_API_KEY를 사용합니다.
# OpenAI GPT LLM, OpenAI STT, OpenAI TTS 모두 LLM_GPT_API_KEY를 사용합니다.
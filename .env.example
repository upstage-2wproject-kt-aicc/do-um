
# Provider API keys (required for actual API calls)
LLM_SOLAR_API_KEY=
LLM_CLAUDE_SONNET_API_KEY=
LLM_GPT_API_KEY=
LLM_GROK_API_KEY=

# Optional observability key (leave empty if unused)
LANGSMITH=

# Provider model names
LLM_SOLAR_MODEL=solar-pro3
LLM_CLAUDE_SONNET_MODEL=claude-sonnet-4
LLM_GPT_MODEL=gpt-4o
LLM_GROK_MODEL=grok-3

# Provider base URLs
LLM_SOLAR_BASE_URL=https://api.upstage.ai/v1
LLM_CLAUDE_SONNET_BASE_URL=https://api.anthropic.com/v1
LLM_GPT_BASE_URL=https://api.openai.com/v1
LLM_GROK_BASE_URL=https://api.x.ai/v1

# Google Vertex AI Gemini (uses GCP billing/credits)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
LLM_GOOGLE_VERTEX_MODEL=gemini-2.5-pro
JUDGE_GOOGLE_VERTEX_MODEL=gemini-3.1-pro-preview

# 저장소 루트에 복사: cp .env.example .env 후 값 입력
# .env 는 Git에 커밋하지 마세요 (.gitignore 처리됨)
# Upstage 임베딩과 Solar LLM 모두 LLM_SOLAR_API_KEY를 사용합니다.
# OpenAI GPT LLM, OpenAI STT, OpenAI TTS 모두 LLM_GPT_API_KEY를 사용합니다.

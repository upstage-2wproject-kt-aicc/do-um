# Provider API keys (required for actual API calls)
LLM_SOLAR_API_KEY=
LLM_CLAUDE_SONNET_API_KEY=
LLM_GPT_API_KEY=
LLM_GROK_API_KEY=

# Optional observability key (leave empty if unused)
LANGSMITH=

# Provider model names
LLM_SOLAR_MODEL=solar-pro3
LLM_CLAUDE_SONNET_MODEL=claude-sonnet-4
LLM_GPT_MODEL=gpt-4o
LLM_GROK_MODEL=grok-3

# Provider base URLs
LLM_SOLAR_BASE_URL=https://api.upstage.ai/v1
LLM_CLAUDE_SONNET_BASE_URL=https://api.anthropic.com/v1
LLM_GPT_BASE_URL=https://api.openai.com/v1
LLM_GROK_BASE_URL=https://api.x.ai/v1
